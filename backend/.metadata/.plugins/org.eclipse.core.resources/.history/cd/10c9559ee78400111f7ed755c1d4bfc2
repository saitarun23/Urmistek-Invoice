package backend.com.entity;

import jakarta.persistence.*;
import lombok.Data;

/**
 * A real login account, scoped to exactly one Company. This is what
 * replaces the old "no auth at all" flow - a user picks their company
 * on the login screen, then authenticates as this user.
 */
@Entity
@Table(name = "app_users", uniqueConstraints = {
        @UniqueConstraint(columnNames = {"company_id", "username"})
})
@Data
public class AppUser {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @Column(nullable = false)
    private String username;

    // BCrypt hash - never store or return the raw password
    @Column(nullable = false)
    private String passwordHash;

    @Column(nullable = false)
    private String displayName;

    @Enumerated(EnumType.STRING)
    private UserRole role = UserRole.STAFF;

    @ManyToOne(fetch = FetchType.LAZY, optional = false)
    @JoinColumn(name = "company_id", nullable = false)
    private Company company;

    private boolean enabled = true;
}
